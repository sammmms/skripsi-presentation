# Live URL of the deployed deck — used to render the QR code on the closing/demo slides.
VITE_DEPLOY_URL=https://skripsi-presentation.vercel.app

# Hugging Face Spaces demo (Gradio) embedded on the prototype slide.
# Must be the *.hf.space app subdomain — the huggingface.co/spaces/... page
# blocks iframing (X-Frame-Options), causing "refused to connect".
VITE_DEMO_URL=https://thesissufferer-deepfake-detection-demo.hf.space

# Supabase Realtime — powers cross-device sync (presence, control hand-off,
# auto-follow) and the live, editable presenter notes. Leave BOTH blank to run
# the deck solo (no networking); the realtime layer simply switches off.
# Project Settings → API → Project URL + publishable key (sb_publishable_…).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
